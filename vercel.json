{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "argus.fzlabs.com" }],
      "destination": "/argus"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "argus.fzlabs.com" }],
      "destination": "/argus/$1"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "swarmix.fzlabs.com" }],
      "destination": "/swarmix"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "swarmix.fzlabs.com" }],
      "destination": "/swarmix/$1"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "signalnews.fzlabs.com" }],
      "destination": "/signalnews"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "signalnews.fzlabs.com" }],
      "destination": "/signalnews/$1"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "f0.fzlabs.com" }],
      "destination": "/f0"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "f0.fzlabs.com" }],
      "destination": "/f0/$1"
    },
    {
      "source": "/",
      "destination": "/main"
    },
    {
      "source": "/(.*)",
      "destination": "/main/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|webp|gif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
